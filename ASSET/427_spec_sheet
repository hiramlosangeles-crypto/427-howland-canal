<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>427 Howland Canal — Property Specification Sheet</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Italiana&family=Instrument+Sans:wght@400;500;600&family=Jura:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  /* ─── DESIGN TOKENS ─────────────────────────────────────── */
  :root {
    --navy:   #1C2B3A;
    --cream:  #EDE8DC;
    --gold:   #C9A55A;
    --mid:    #8A9BA8;
    --rule:   #D5CEBE;
    --photo:  #C8D5DC;
    --white:  #FFFFFF;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--cream);
    font-family: 'Instrument Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: var(--navy);
    -webkit-font-smoothing: antialiased;
  }

  /* ─── PAGE WRAPPER ───────────────────────────────────────── */
  .page {
    max-width: 816px;
    margin: 0 auto;
    background: var(--cream);
    position: relative;
  }

  /* ─── NAVBAR ─────────────────────────────────────────────── */
  .navbar {
    background: var(--navy);
    height: 54px;
    display: flex;
    align-items: center;
    padding: 0 28px;
    gap: 12px;
  }
  .navbar-logo {
    width: 28px; height: 28px;
    background: var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .navbar-logo span {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 11px;
    color: var(--navy);
  }
  .navbar-brand {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 9.5px;
    color: var(--white);
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .navbar-contact {
    margin-left: auto;
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 8px;
    color: var(--gold);
    letter-spacing: 0.8px;
    text-align: right;
  }

  /* ─── HERO ───────────────────────────────────────────────── */
  .hero {
    background: var(--photo);
    height: 236px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .hero-placeholder {
    border: 0.6px solid #8AABB8;
    position: absolute;
    inset: 23px 46px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-placeholder span {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 8.5px;
    color: #8AABB8;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  /* ── spec ribbon over hero bottom ── */
  .hero-tag {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: rgba(28,43,58,0.82);
    padding: 6px 46px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-tag-badge {
    font-family: 'Jura', monospace;
    font-size: 7px;
    letter-spacing: 1.8px;
    color: var(--gold);
    text-transform: uppercase;
    border: 0.6px solid var(--gold);
    padding: 2px 6px;
    white-space: nowrap;
  }
  .hero-tag-dot { color: var(--gold); font-size: 6px; }
  .hero-tag-id {
    font-family: 'Jura', monospace;
    font-size: 7.5px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.8px;
    margin-left: auto;
  }

  /* ─── ADDRESS BLOCK ──────────────────────────────────────── */
  .address-block {
    text-align: center;
    padding: 26px 46px 12px;
  }
  .address-district {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 8px;
    color: var(--gold);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .address-headline {
    font-family: 'Italiana', Georgia, serif;
    font-size: 46px;
    color: var(--navy);
    line-height: 1;
    margin-bottom: 8px;
  }
  .address-rule {
    width: 68px;
    height: 3px;
    background: var(--gold);
    margin: 0 auto 10px;
  }
  .address-sub {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 10px;
    color: var(--mid);
    letter-spacing: 0.8px;
  }

  /* ─── STAT TILES ─────────────────────────────────────────── */
  .stat-tiles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 16px 46px 0;
  }
  .tile {
    background: var(--navy);
    padding: 14px 10px 12px;
    text-align: center;
    position: relative;
  }
  .tile + .tile { border-left: 1px solid rgba(255,255,255,0.08); }
  .tile-value {
    font-family: 'Italiana', Georgia, serif;
    font-size: 22px;
    color: var(--white);
    line-height: 1.1;
    display: block;
    margin-bottom: 4px;
  }
  .tile-label {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 7px;
    color: var(--gold);
    letter-spacing: 1.2px;
    text-transform: uppercase;
    display: block;
  }

  /* second row tiles — lighter */
  .stat-tiles-2 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 3px 46px 0;
  }
  .tile-2 {
    background: rgba(28,43,58,0.08);
    border-top: 2px solid var(--gold);
    padding: 10px 10px 10px;
    text-align: center;
  }
  .tile-2 + .tile-2 { border-left: 1px solid var(--rule); }
  .tile-2-value {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: var(--navy);
    display: block;
    margin-bottom: 3px;
  }
  .tile-2-label {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 7px;
    color: var(--mid);
    letter-spacing: 1px;
    text-transform: uppercase;
    display: block;
  }

  /* ─── DIVIDER ─────────────────────────────────────────────── */
  .divider {
    height: 0.6px;
    background: var(--rule);
    margin: 22px 46px 0;
  }

  /* ─── BODY GRID ──────────────────────────────────────────── */
  .body-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 32px;
    padding: 24px 46px 0;
  }

  /* ─── SECTION ─────────────────────────────────────────────── */
  .section { margin-bottom: 28px; }
  .section-title {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 8.5px;
    color: var(--navy);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .section-rule {
    width: 28px; height: 2.5px;
    background: var(--gold);
    margin-bottom: 12px;
  }

  /* ─── DATA ROWS (spec-sheet style) ──────────────────────── */
  .data-row {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 7px;
  }
  .data-label {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 7.5px;
    color: var(--mid);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .data-dots {
    flex: 1;
    border-bottom: 0.5px dashed var(--rule);
    margin-bottom: 2px;
    min-width: 8px;
  }
  .data-value {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 9px;
    font-weight: 600;
    color: var(--navy);
    text-align: right;
    white-space: nowrap;
  }

  /* ─── BULLET ITEMS ───────────────────────────────────────── */
  .bullet-list { list-style: none; padding: 0; }
  .bullet-list li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 9.5px;
    color: var(--navy);
    line-height: 1.45;
  }
  .bullet-list li::before {
    content: '';
    width: 7px; height: 7px;
    background: var(--gold);
    border-radius: 1px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ─── TAG CHIPS ──────────────────────────────────────────── */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 4px;
  }
  .tag {
    font-family: 'Jura', monospace;
    font-size: 7px;
    letter-spacing: 0.6px;
    color: var(--mid);
    border: 0.5px solid var(--rule);
    padding: 2px 6px;
    text-transform: uppercase;
  }

  /* ─── FULL-WIDTH SECTION ─────────────────────────────────── */
  .full-section {
    padding: 0 46px;
    margin-bottom: 24px;
  }

  /* ─── ABOUT BLURB ────────────────────────────────────────── */
  .about-text {
    font-family: 'Italiana', Georgia, serif;
    font-size: 11px;
    font-style: italic;
    color: var(--navy);
    line-height: 1.7;
  }
  .about-tags {
    font-family: 'Jura', monospace;
    font-size: 8px;
    color: var(--mid);
    letter-spacing: 0.4px;
    margin-top: 8px;
  }

  /* ─── CONTACT ────────────────────────────────────────────── */
  .contact-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 32px;
    padding: 0 46px 0;
  }
  .contact-name {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--navy);
  }
  .contact-brokerage {
    font-family: 'Jura', monospace;
    font-size: 8px;
    color: var(--gold);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin: 3px 0;
  }
  .contact-lic {
    font-family: 'Jura', monospace;
    font-size: 7.5px;
    color: var(--mid);
    margin-bottom: 10px;
  }
  .contact-detail {
    font-family: 'Instrument Sans', sans-serif;
    font-size: 10px;
    color: var(--navy);
    margin-bottom: 3px;
  }
  .contact-website {
    font-family: 'Italiana', Georgia, serif;
    font-size: 14px;
    font-style: italic;
    color: var(--navy);
    margin-top: 6px;
    display: block;
  }

  /* ─── FOOTER ─────────────────────────────────────────────── */
  .footer {
    background: var(--navy);
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 32px;
  }
  .footer span {
    font-family: 'Jura', 'Courier New', monospace;
    font-size: 7px;
    color: var(--gold);
    letter-spacing: 0.4px;
    text-align: center;
  }

  /* ─── PRINT / MEDIA ──────────────────────────────────────── */
  @media print {
    body { background: var(--cream); }
    .page { max-width: 100%; }
  }
</style>
</head>
